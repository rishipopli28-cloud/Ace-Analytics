# ── ACE Analytics v3 — Environment Variables ─────────────────────────────────

PORT=3000

# MongoDB connection string
# Local:  mongodb://localhost:27017/aceanalytics
# Atlas:  mongodb+srv://user:pass@cluster.mongodb.net/aceanalytics
MONGODB_URI=mongodb://localhost:27017/aceanalytics

# JWT secret (change to a long random string in production)
JWT_SECRET=ace_analytics_jwt_super_secret_key_change_this_in_production

# AES encryption key for broker API keys (exactly 32 characters)
ENC_KEY=aceanalytics32bytesecretkey12345

# Alpha Vantage — RSI, MACD, Moving Averages
# Free: https://alphavantage.co/support/#api-key
ALPHA_VANTAGE_KEY=your_alpha_vantage_key_here

# NewsAPI — Live headlines + sentiment
# Free: https://newsapi.org/register
NEWS_API_KEY=your_newsapi_key_here

# SMS OTP — Twilio (optional, fallback: OTP logged to console)
# Get credentials: https://twilio.com/console
TWILIO_SID=your_twilio_account_sid
TWILIO_TOKEN=your_twilio_auth_token
TWILIO_FROM=+1234567890

# JWT expiry
JWT_EXPIRES=7d
